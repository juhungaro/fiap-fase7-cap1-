# CardioIA — Configurações do Backend (Fase 7)

# Porta e host do servidor
PORT=8000
HOST=0.0.0.0

# Chaves de IA (OpenAI e Watson Assistant)
# Caso não fornecidas, o backend usará respostas locais simuladas (fallback) de forma transparente
OPENAI_API_KEY=sk-proj-...
CARDIO_AGENT_MODEL=gpt-4o-mini

# Watson Assistant (Fase 5) - Opcional se preferir usar a OpenAI para o chatbot
WATSON_APIKEY=
WATSON_URL=
WATSON_ASSISTANT_ID=
